// Clovion CMS — Prisma schema
// Postgres 16 + pgvector. Prisma 6.x.
//
// Modeling notes:
// - Generic creator/updater/owner columns (createdById, updatedById, uploadedById,
//   requestedById, updatedBy) are kept as plain String? @db.Uuid foreign-key-less
//   columns (no @relation) to avoid dozens of back-relation arrays on User. They are
//   FKs by convention (to User) but not enforced at the Prisma relation level.
// - Real, named relations are only declared where the app needs to traverse them.
// - Soft delete (deletedAt) is only on ContentItem and MediaAsset.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  // App connection. On Supabase use the POOLED connection (pgBouncer, port 6543,
  // ?pgbouncer=true). Locally this is the Docker Postgres.
  url        = env("DATABASE_URL")
  // Direct connection used for migrations (Supabase port 5432). Locally it can
  // equal DATABASE_URL.
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ──────────────────────────────────────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  EDITOR
  AUTHOR
  CONTRIBUTOR
  VIEWER
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum ContentType {
  BLOG
  RESEARCH
  WEBINAR
  NEWS
  RESOURCE
  COURSE
  FAQ
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  SCHEDULED
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum RevisionSource {
  MANUAL
  AI_GENERATION
  AUTOSAVE
}

enum MediaKind {
  IMAGE
  VIDEO
  PDF
  OTHER
}

enum KbSourceType {
  DOC
  URL
  PASTED_TEXT
  PDF
}

enum KbStatus {
  PROCESSING
  READY
  FAILED
}

enum AiMode {
  FULL_DRAFT
  SECTION
  REWRITE
  OUTLINE
}

enum AiJobStatus {
  QUEUED
  STREAMING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum ScheduledAction {
  PUBLISH
  UNPUBLISH
}

enum ScheduledStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  CANCELLED
}

// ──────────────────────────────────────────────────────────────────────────────
// CORE / IDENTITY
// ──────────────────────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique
  name            String?
  role            Role       @default(CONTRIBUTOR)
  status          UserStatus @default(INVITED)
  passwordHash    String?
  authorProfileId String?    @unique @db.Uuid
  lastLoginAt     DateTime?
  // Invite flow (FR-USER-01): a one-time token emailed to a new user so they
  // can set a password and become ACTIVE. Cleared once consumed.
  inviteToken        String?   @unique
  inviteTokenExpires DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  authorProfile  AuthorProfile? @relation("UserAuthorProfile", fields: [authorProfileId], references: [id])
  createdContent ContentItem[]  @relation("ContentCreatedBy")
  auditLogs      AuditLog[]     @relation("AuditLogActor")

  // Auth.js
  accounts Account[]
  sessions Session[]

  @@map("users")
}

model AuthorProfile {
  id            String   @id @default(uuid()) @db.Uuid
  displayName   String
  slug          String   @unique
  title         String? // job title / role shown on the public byline (e.g. "Content Manager")
  bio           String?  @db.Text
  avatarAssetId String?  @db.Uuid
  socialLinks   Json     @default("{}")
  isPublic      Boolean  @default(false)
  isGhost       Boolean  @default(false) // guest byline, no login (PRD Q1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?  @db.Uuid
  updatedById   String?  @db.Uuid

  // Relations
  user         User?         @relation("UserAuthorProfile")
  contentItems ContentItem[] @relation("ContentByline")

  @@map("author_profiles")
}

// ──────────────────────────────────────────────────────────────────────────────
// CONTENT
// ──────────────────────────────────────────────────────────────────────────────

model ContentItem {
  id                String        @id @default(uuid()) @db.Uuid
  type              ContentType
  title             String
  slug              String
  body              Json // Tiptap doc
  bodyHtml          String?       @db.Text
  excerpt           String?       @db.Text
  coverAssetId      String?       @db.Uuid
  status            ContentStatus @default(DRAFT)
  scheduledAt       DateTime?
  publishedAt       DateTime?
  authorProfileId   String        @db.Uuid
  seo               Json          @default("{}")
  schemaMarkup      Json          @default("{}")
  categoryId        String?       @db.Uuid
  typeData          Json          @default("{}")
  currentRevisionId String?       @db.Uuid
  deletedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  createdById       String?       @db.Uuid
  updatedById       String?       @db.Uuid

  // Relations
  authorProfile   AuthorProfile     @relation("ContentByline", fields: [authorProfileId], references: [id])
  category        Category?         @relation("ContentCategory", fields: [categoryId], references: [id])
  coverAsset      MediaAsset?       @relation("ContentCoverAsset", fields: [coverAssetId], references: [id])
  createdBy       User?             @relation("ContentCreatedBy", fields: [createdById], references: [id])
  revisions       ContentRevision[] @relation("ContentRevisions")
  currentRevision ContentRevision?  @relation("ContentCurrentRevision", fields: [currentRevisionId], references: [id])
  tags            Tag[]             @relation("ContentTags")
  scheduledJobs   ScheduledJob[]    @relation("ContentScheduledJobs")
  aiJobs          AIGenerationJob[] @relation("ContentAiJobs")

  @@unique([type, slug])
  @@index([type, status])
  @@index([status, scheduledAt])
  @@index([publishedAt])
  // Public read API lists published content ordered by publishedAt (NFR-PERF-01).
  @@index([status, publishedAt])
  @@map("content_items")
}

model ContentRevision {
  id           String         @id @default(uuid()) @db.Uuid
  contentId    String         @db.Uuid
  body         Json
  seo          Json
  typeData     Json
  revisionNote String?
  source       RevisionSource
  createdAt    DateTime       @default(now())
  createdById  String?        @db.Uuid

  // Relations
  content    ContentItem   @relation("ContentRevisions", fields: [contentId], references: [id])
  currentFor ContentItem[] @relation("ContentCurrentRevision")

  @@index([contentId, createdAt])
  @@map("content_revisions")
}

// ──────────────────────────────────────────────────────────────────────────────
// MEDIA
// ──────────────────────────────────────────────────────────────────────────────

model MediaAsset {
  id           String    @id @default(uuid()) @db.Uuid
  kind         MediaKind
  storageKey   String
  url          String
  filename     String
  mimeType     String
  sizeBytes    BigInt
  width        Int?
  height       Int?
  durationS    Int?
  altText      String?
  caption      String?   @db.Text
  variants     Json      @default("{}")
  uploadedById String?   @db.Uuid
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  String?   @db.Uuid
  updatedById  String?   @db.Uuid

  // Relations
  coverFor ContentItem[] @relation("ContentCoverAsset")

  @@index([kind])
  @@map("media_assets")
}

// ──────────────────────────────────────────────────────────────────────────────
// EDITORIAL / AI CONFIG
// ──────────────────────────────────────────────────────────────────────────────

model WritingSOP {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  body        String        @db.Text
  appliesTo   ContentType[]
  isActive    Boolean       @default(false)
  version     Int           @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById String?       @db.Uuid
  updatedById String?       @db.Uuid

  @@map("writing_sops")
}

// ──────────────────────────────────────────────────────────────────────────────
// KNOWLEDGE BASE (RAG)
// ──────────────────────────────────────────────────────────────────────────────

model KnowledgeBaseItem {
  id          String       @id @default(uuid()) @db.Uuid
  title       String
  sourceType  KbSourceType
  rawContent  String       @db.Text
  tags        String[]
  status      KbStatus     @default(PROCESSING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdById String?      @db.Uuid

  // Relations
  chunks KnowledgeBaseChunk[] @relation("KbItemChunks")

  @@map("knowledge_base_items")
}

model KnowledgeBaseChunk {
  id         String                       @id @default(uuid()) @db.Uuid
  kbItemId   String                       @db.Uuid
  chunkText  String                       @db.Text
  // pgvector column. Prisma has no native vector type, so it is modeled as
  // Unsupported. Similarity retrieval is done via raw SQL (e.g. `embedding <=> $1`).
  // A vector index (ivfflat or hnsw) is added via migration SQL, for example:
  //   CREATE INDEX ON knowledge_base_chunks USING hnsw (embedding vector_cosine_ops);
  embedding  Unsupported("vector(1536)")?
  tokenCount Int
  createdAt  DateTime                     @default(now())

  // Relations
  kbItem KnowledgeBaseItem @relation("KbItemChunks", fields: [kbItemId], references: [id], onDelete: Cascade)

  @@index([kbItemId])
  @@map("knowledge_base_chunks")
}

model AIProviderConfig {
  id                        String   @id @default(uuid()) @db.Uuid
  openrouterApiKeyEncrypted String? // encrypted at rest (legacy in-editor AI Write)
  anthropicApiKeyEncrypted  String? // encrypted at rest (Content Agent: orchestrator/writer)
  openaiApiKeyEncrypted     String? // encrypted at rest (Content Agent: QA + embeddings)
  defaultModel              String?
  embeddingModel            String?
  maxTokens                 Int      @default(4000)
  temperature               Float    @default(0.7)
  monthlyBudgetUsd          Decimal? @db.Decimal(10, 2)
  // Per-role model overrides for the Content Agent pipeline:
  // { "orchestrator": "...", "writer": "...", "qa": "..." } (OpenRouter ids).
  agentModels               Json     @default("{}")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  updatedById               String?  @db.Uuid

  @@map("ai_provider_configs")
}

model AIGenerationJob {
  id               String      @id @default(uuid()) @db.Uuid
  contentId        String?     @db.Uuid
  requestedById    String?     @db.Uuid
  mode             AiMode
  promptAssembly   Json        @default("{}")
  model            String?
  status           AiJobStatus @default(QUEUED)
  outputTiptap     Json?
  tokensPrompt     Int?
  tokensCompletion Int?
  costUsd          Decimal?    @db.Decimal(10, 4)
  lowGrounding     Boolean     @default(false)
  error            Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Relations
  content ContentItem? @relation("ContentAiJobs", fields: [contentId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@map("ai_generation_jobs")
}

// ──────────────────────────────────────────────────────────────────────────────
// SCHEDULING
// ──────────────────────────────────────────────────────────────────────────────

model ScheduledJob {
  id        String          @id @default(uuid()) @db.Uuid
  contentId String          @db.Uuid
  action    ScheduledAction
  runAt     DateTime
  status    ScheduledStatus @default(PENDING)
  attempts  Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Relations
  content ContentItem @relation("ContentScheduledJobs", fields: [contentId], references: [id])

  @@index([status, runAt])
  @@map("scheduled_jobs")
}

// ──────────────────────────────────────────────────────────────────────────────
// AUDIT (append-only)
// ──────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  entityType String
  entityId   String   @db.Uuid
  action     String
  diff       Json?
  at         DateTime @default(now())

  // Relations
  actor User? @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId, at])
  @@index([at])
  @@map("audit_logs")
}

// ──────────────────────────────────────────────────────────────────────────────
// TAXONOMY
// ──────────────────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?  @db.Uuid
  updatedById String?  @db.Uuid

  // Relations
  contentItems ContentItem[] @relation("ContentCategory")

  @@map("categories")
}

model Tag {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?  @db.Uuid
  updatedById String?  @db.Uuid

  // Relations
  contentItems ContentItem[] @relation("ContentTags")

  @@map("tags")
}

// ──────────────────────────────────────────────────────────────────────────────
// AUTH.JS (NextAuth v5 + @auth/prisma-adapter)
// ──────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Org-level workflow policy, runtime-editable by an Admin (Phase 3).
// Singleton row. Replaces the env-var defaults previously read in policy.ts.
//   - selfPublish: Authors may self-publish/schedule their own content.
//   - newsFastPublish: NEWS gets an Author self-publish lane.
//   - webinarAutoRecorded: after a webinar's end_at, auto-flip is_live ->
//     is_recorded when a recording_url is present (FR §6.2 webinar delta).
model OrgPolicy {
  id                  String   @id @default(uuid()) @db.Uuid
  selfPublish         Boolean  @default(false)
  newsFastPublish     Boolean  @default(true)
  webinarAutoRecorded Boolean  @default(false)
  updatedById         String?  @db.Uuid
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("org_policy")
}

// Gated-resource lead capture (Phase 3, NG3/NFR-SEC-03, PRD Q4).
// A RESOURCE's typeData.leadFormId references a LeadForm; the public site shows
// the form (not the PDF URL); on submit, a signed, expiring download URL is
// issued. `fields` is an ordered array of { name, label, type, required }.
model LeadForm {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  fields      Json     @default("[]")
  isActive    Boolean  @default(true)
  createdById String?  @db.Uuid
  updatedById String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions LeadSubmission[]

  @@map("lead_forms")
}

model LeadSubmission {
  id         String   @id @default(uuid()) @db.Uuid
  leadFormId String   @db.Uuid
  contentId  String?  @db.Uuid
  email      String
  data       Json     @default("{}")
  ipHash     String?
  createdAt  DateTime @default(now())

  leadForm LeadForm @relation(fields: [leadFormId], references: [id], onDelete: Cascade)

  @@index([leadFormId, createdAt])
  @@index([contentId])
  @@map("lead_submissions")
}

// ──────────────────────────────────────────────────────────────────────────────
// AGENT API KEYS — scoped keys for the external agent API (/api/agent/v1).
// Plaintext keys are shown once at mint time; only a sha256 hash is stored.
// Draft-only by scope: v1 issues ["content:draft:create"] and nothing else.
// ──────────────────────────────────────────────────────────────────────────────

model ApiKey {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  // sha256 hex digest of the plaintext key. Never store or log the plaintext.
  keyHash         String    @unique
  // Non-secret display prefix (e.g. "agk_1a2b3c4d") for identifying keys in logs/UI.
  keyPrefix       String
  // Capability scopes, e.g. "content:draft:create". Checked on every request.
  scopes          String[]  @default([])
  // Byline for content created with this key (typically an isGhost AuthorProfile).
  // FK-less by convention (see header note on generic creator columns).
  authorProfileId String?   @db.Uuid
  // Admin who minted the key. FK-less by convention.
  createdById     String?   @db.Uuid
  expiresAt       DateTime?
  revokedAt       DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("api_keys")
}

// ──────────────────────────────────────────────────────────────────────────────
// CONTENT AGENT — multi-role generation runs (orchestrator → writer → QA).
// Runs are a library: every generation is kept, statused, and reusable.
// Output is ALWAYS a draft-side artifact; "send to blog" creates a DRAFT
// ContentItem through the normal create path (never publishes).
// ──────────────────────────────────────────────────────────────────────────────

enum AgentChannel {
  LINKEDIN_PERSONAL
  LINKEDIN_COMPANY
  META_SOCIAL // legacy (pre Facebook/Instagram split)
  FACEBOOK
  INSTAGRAM
  BLOG_ARTICLE
  REPORT_ARTICLE // legacy (folded into BLOG_ARTICLE "from-report" angle)
  WEBSITE
}

enum AgentRunStatus {
  QUEUED
  PLANNING
  WRITING
  QA
  REVISING
  READY
  FAILED
  CANCELLED
}

model AgentRun {
  id           String         @id @default(uuid()) @db.Uuid
  channel      AgentChannel
  postType     String
  // Visual format (social channels): static, infographic, carousel.
  format       String?
  // Allow the orchestrator to run quick web research to back claims with data.
  allowResearch Boolean       @default(true)
  // SEO keywords (website content): first entry is the primary keyword.
  keywords     String[]       @default([])
  // Artboard size for visual formats ("1080x1350"); null = agent recommends.
  designSize   String?
  // Course outlines: the editable, structured lesson plan derived from the
  // outline text. Source of truth for one-click course generation.
  outlineSyllabus Json?
  // filed into that course (typeData.courseSlug) instead of the blog.
  targetCourseSlug String?
  brief        String         @db.Text
  // Raw source material (e.g. a research report) for REPORT_ARTICLE runs.
  sourceReport String?        @db.Text
  status       AgentRunStatus @default(QUEUED)
  // Orchestrator output: { angle, structure, keyPoints, mustInclude, ... }
  plan         Json?
  // Primary deliverable: the written-out content (articles: HTML).
  draftText    String?        @db.Text
  // Graphic/slide spec (infographic & carousel runs) — editable separately.
  specText     String?        @db.Text
  // Accompanying caption (infographic/carousel runs) — editable separately.
  captionText  String?        @db.Text
  // QA verdict: { pass, scores: {...}, requiredFixes: [], notes }
  qaReport     Json?
  revisionRounds Int          @default(0)
  // User feedback history: [{ at, note }]
  feedback     Json           @default("[]")
  error        Json?
  tokensPrompt     Int        @default(0)
  tokensCompletion Int        @default(0)
  costUsd          Decimal    @default(0) @db.Decimal(10, 4)
  // Set when an article run is filed into the blog (ContentItem id).
  contentId    String?        @db.Uuid
  // Approval: marks the run as shipped; triggers the learning pass.
  approvedAt   DateTime?
  // Snapshot of the first READY output (pre-feedback/pre-edits) for learning.
  firstOutput  String?        @db.Text
  createdById  String?        @db.Uuid
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
  @@map("agent_runs")
}

// Durable style rules learned from approved runs (first output vs shipped).
// Injected into future prompts for the same channel; deletable in the UI.
model AgentLesson {
  id          String       @id @default(uuid()) @db.Uuid
  channel     AgentChannel
  format      String?
  lesson      String       @db.Text
  sourceRunId String?      @db.Uuid
  isActive    Boolean      @default(true)
  createdById String?      @db.Uuid
  createdAt   DateTime     @default(now())

  @@index([channel, isActive, createdAt])
  @@map("agent_lessons")
}

// ──────────────────────────────────────────────────────────────────────────────
// COURSE BATCH — one-click course generation from an approved outline run.
// Lessons chain sequentially (each fed the outline + prior lessons); template
// assets (docx/xlsx) are generated per lesson into the media library.
// ──────────────────────────────────────────────────────────────────────────────

enum CourseBatchStatus {
  PLANNING
  RUNNING
  READY
  FAILED
}

model CourseBatch {
  id            String            @id @default(uuid()) @db.Uuid
  outlineRunId  String            @unique @db.Uuid
  courseTitle   String?
  // { courseTitle, lessons: [{ n, title, brief, assets: [{name, kind, description}] }] }
  syllabus      Json?
  status        CourseBatchStatus @default(PLANNING)
  currentLesson Int               @default(0)
  lessonRunIds  Json              @default("[]")
  error         Json?
  createdById   String?           @db.Uuid
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("course_batches")
}

enum AgentAssetStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

// Generated downloadable files (lesson templates/checklists) linked to runs.
model AgentAsset {
  id           String           @id @default(uuid()) @db.Uuid
  runId        String           @db.Uuid
  target       String
  kind         String // "docx" | "xlsx"
  filename     String?
  status       AgentAssetStatus @default(PENDING)
  mediaAssetId String?          @db.Uuid
  error        Json?
  createdById  String?          @db.Uuid
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([runId, target])
  @@index([runId])
  @@map("agent_assets")
}
