# ─── Database (Postgres + pgvector) ───────────────────────────────
# Local dev: matches docker-compose.yml. DIRECT_URL can equal DATABASE_URL.
# Production (Supabase): DATABASE_URL = POOLED connection
#   (…pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1);
#   DIRECT_URL = DIRECT connection (…supabase.com:5432/postgres). Enable the
#   `vector` extension in Supabase (Database → Extensions).
DATABASE_URL="postgresql://clovion:clovion@localhost:5433/clovion_cms?schema=public"
DIRECT_URL="postgresql://clovion:clovion@localhost:5433/clovion_cms?schema=public"

# ─── Redis (BullMQ scheduled-publish + AI/ingestion jobs) ─────────
# Production: a managed Redis (e.g. Railway Redis or Upstash).
REDIS_URL="redis://localhost:6380"

# ─── Email (FR-USER-01 invites, FR-CONTENT-06 notifications) ──────
# Without SMTP, emails are logged (invite links recoverable from logs).
EMAIL_FROM="Clovion CMS <no-reply@clovion.ai>"
SMTP_URL=""
# or SMTP_HOST / SMTP_PORT / SMTP_SECURE / SMTP_USER / SMTP_PASS

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
AUTH_URL="http://localhost:3007"
NEXTAUTH_URL="http://localhost:3007"

# OAuth providers (optional for email-invite flow)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ─── Secrets encryption (AIProviderConfig key at rest, NFR-SEC-01) ─
# 32-byte key, base64. Generate with: openssl rand -base64 32
ENCRYPTION_KEY="change-me-32-byte-base64-key===="

# ─── S3-compatible object storage (media + gated PDFs) ────────────
S3_ENDPOINT="http://localhost:9100"
S3_REGION="us-east-1"
S3_BUCKET="clovion-cms-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL="http://localhost:9100/clovion-cms-media"
S3_FORCE_PATH_STYLE="true"

# ─── Public site integration (read API consumer) ─────────────────
PUBLIC_SITE_WEBHOOK_URL=""
PUBLIC_SITE_CACHE_PURGE_TOKEN=""

# ─── OpenRouter (Phase 2 — scaffolded only, not wired in Phase 1) ──
# Key is stored encrypted in AIProviderConfig via the admin UI; this
# env var is only a dev fallback.
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_APP_TITLE="Clovion CMS"
OPENROUTER_HTTP_REFERER="https://cms.clovion.ai"
